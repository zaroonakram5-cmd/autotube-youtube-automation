# ===========================================
# DATABASE
# ===========================================
DATABASE_URL="postgresql://user:password@localhost:5432/youtube_automation?schema=public"

# ===========================================
# REDIS (for job queues)
# ===========================================
REDIS_URL="redis://localhost:6379"

# ===========================================
# AUTHENTICATION
# ===========================================
JWT_SECRET="your-super-secret-jwt-key-change-in-production"
# Generate with: openssl rand -hex 32

# ===========================================
# APPLICATION
# ===========================================
NEXT_PUBLIC_APP_URL="http://localhost:3000"
NODE_ENV="development"

# ===========================================
# AI API KEYS - Get these from each service
# ===========================================

# --- Google Gemini (https://makersuite.google.com/app/apikey) ---
GEMINI_API_KEY="AIzaSyXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# --- OpenAI (https://platform.openai.com/api-keys) ---
OPENAI_API_KEY="sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# --- Anthropic / Claude (https://console.anthropic.com/settings/keys) ---
ANTHROPIC_API_KEY="sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# --- Groq (https://console.groq.com/keys) ---
GROQ_API_KEY="gsk_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# --- OpenRouter (https://openrouter.ai/keys) ---
OPENROUTER_API_KEY="sk-or-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# --- Replicate (https://replicate.com/account/api-tokens) ---
REPLICATE_API_KEY="r8_XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# --- ElevenLabs (https://elevenlabs.io/app/api-key) ---
ELEVENLABS_API_KEY="xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx"

# --- Stability AI (https://platform.stability.ai/account/api-key) ---
STABILITY_API_KEY="sk-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"

# ===========================================
# EDGE TTS (No API key required - uses Windows voices)
# ===========================================
# Edge TTS is free and doesn't need an API key
# Install: pip install edge-tts
EDGE_TTS_PATH="/usr/local/bin/edge-tts"

# ===========================================
# VIDEO RENDERING
# ===========================================
# FFmpeg path (install: sudo apt install ffmpeg)
FFMPEG_PATH="/usr/bin/ffmpeg"

# Storage
STORAGE_PATH="./storage"

# ===========================================
# OPTIONAL: Cloud Storage (S3 Compatible)
# ===========================================
# AWS_S3_BUCKET="your-bucket-name"
# AWS_S3_REGION="us-east-1"
# AWS_ACCESS_KEY_ID="your-access-key"
# AWS_SECRET_ACCESS_KEY="your-secret-key"

# ===========================================
# OPTIONAL: R2 Storage (Cloudflare)
# ===========================================
# R2_ACCOUNT_ID="your-account-id"
# R2_ACCESS_KEY_ID="your-access-key"
# R2_SECRET_ACCESS_KEY="your-secret-key"
# R2_BUCKET_NAME="your-bucket-name"
